<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Daily Expense Tracker</title>
    <style>
        :root {
            --primary-blue: #003366;
            --accent-yellow: #FFD700;
            --bg-light: #f4f7f6;
            --white: #ffffff;
            --text-main: #333;
            --text-muted: #666;
            --border-color: #e0e0e0;
        }

        * {
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg-light);
            margin: 0;
            padding: 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .container {
            background: var(--white);
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0, 51, 102, 0.1);
            width: 100%;
            max-width: 450px; /* Slightly wider to accommodate side-by-side inputs */
            border-top: 8px solid var(--primary-blue);
        }

        header h1 {
            color: var(--primary-blue);
            margin-bottom: 0.5rem;
            text-align: center;
            font-size: 1.6rem;
        }

        .highlight { color: var(--accent-yellow); }

        header p {
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
            margin-bottom: 1.5rem;
        }

        .input-group {
            margin-bottom: 1.5rem;
        }

        .input-group label {
            display: block;
            font-weight: 600;
            color: var(--primary-blue);
            margin-bottom: 0.6rem;
            font-size: 0.9rem;
        }

        /* Flex container for the two inputs */
        .input-row {
            display: flex;
            gap: 10px;
        }

        .input-row input[type="number"] {
            flex: 2; /* Amount gets more space */
        }

        .input-row input[type="text"] {
            flex: 3; /* Description gets more space */
        }

        input {
            width: 100%;
            padding: 12px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            font-size: 16px; /* Best for mobile OS prevents zoom */
            transition: border-color 0.3s;
            background: #fafafa;
        }

        input:focus {
            outline: none;
            border-color: var(--primary-blue);
            background: #fff;
        }

        .submit-btn {
            width: 100%;
            padding: 15px;
            background-color: var(--primary-blue);
            color: var(--white);
            border: none;
            border-radius: 10px;
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: opacity 0.3s;
        }

        /* Responsive stack for very small screens */
        @media (max-width: 400px) {
            .input-row {
                flex-direction: column;
            }
            .container {
                padding: 1.2rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <header>
            <h1>Daily Expense <span class="highlight">Log</span></h1>
            <p>Manage your PKR expenses effortlessly.</p>
        </header>

        <form action="/addexpense" method="POST">
            <div class="input-group">
                <label for="petrol">Petrol</label>
                <div class="input-row">
                    <input type="number" id="petrol" name="petrol_amount" placeholder="PKR" min="0" inputmode="numeric">
                    <input type="text" name="petrol_desc" id="petrol_des" placeholder="Details...">
                </div>
            </div>

            <div class="input-group">
                <label for="food">Food</label>
                <div class="input-row">
                    <input type="number" id="food" name="food_amount" placeholder="PKR" min="0" inputmode="numeric">
                    <input type="text" name="food_desc" id="food_des" placeholder="Details...">
                </div>
            </div>

            <div class="input-group">
                <label for="others">Others</label>
                <div class="input-row">
                    <input type="number" id="others" name="others_amount" placeholder="PKR" min="0" inputmode="numeric">
                    <input type="text" name="others_desc" id="others_des" placeholder="Details...">
                </div> 
            </div>

            <button type="submit" class="submit-btn">Save Daily Log</button>
        </form>
    </div>
</body>
</html>